{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Claude Code Dashboard",
  "version": "2.4.0",
  "identifier": "com.claude-code-dashboard.app",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:3456",
    "beforeBuildCommand": "node copy-resources.js"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Claude Code Dashboard",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "url": "http://localhost:3456"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../app/**/*"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installMode": "perMachine"
      }
    }
  }
}
